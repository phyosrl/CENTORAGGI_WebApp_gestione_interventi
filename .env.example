# Dataverse Configuration

# Microsoft Dataverse Environment
DATAVERSE_URL=https://your-org.crm.dynamics.com
DATAVERSE_CLIENT_ID=your-client-id
DATAVERSE_CLIENT_SECRET=your-client-secret
DATAVERSE_TENANT_ID=your-tenant-id

# SharePoint (Microsoft Graph) - usa lo stesso tenant del Dataverse
# Host: dominio SharePoint del tenant (senza https://)
SHAREPOINT_TENANT_HOST=yourtenant.sharepoint.com
# Path del sito (parte dopo l'host). Es. /sites/all oppure /sites/Assistenze
SHAREPOINT_SITE_PATH=/sites/all
# Nome della document library (drive). Default: "Documents" (Documenti condivisi)
SHAREPOINT_DRIVE_NAME=Documents
# Cartella radice dentro la library dove creare le sottocartelle per registrazione
SHAREPOINT_ROOT_FOLDER=Assistenze
# Scope Graph (di solito non serve cambiare)
GRAPH_SCOPE=https://graph.microsoft.com/.default

# Database
DATABASE_URL=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=your-db;Persist Security Info=False;User ID=your-user;Password=your-password;Encrypt=True;Connection Timeout=30;

# Environment
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGIN=*
